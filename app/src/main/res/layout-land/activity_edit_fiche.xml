<?xml version="1.0" encoding="utf-8"?>
<!-- Écran de création d'une fiche (mode PAYSAGE) :
     on adapte la disposition -> formulaire à gauche, photo + boutons à droite.
     Les @+id sont identiques à la version portrait, donc le code Java
     fonctionne sans changement (consigne n°1 : adaptation portrait/paysage). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Colonne gauche : champs texte -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/champ_titre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/titre_fiche"
                android:inputType="text" />

            <EditText
                android:id="@+id/champ_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/note"
                android:inputType="textMultiLine"
                android:minLines="2" />

            <TextView
                android:id="@+id/texte_gps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:text="@string/gps_attente" />
        </LinearLayout>
    </ScrollView>

    <!-- Colonne droite : photo + boutons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingLeft="16dp">

        <ImageView
            android:id="@+id/apercu_photo"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#EEEEEE"
            android:contentDescription="@string/photo"
            android:scaleType="centerCrop" />

        <Button
            android:id="@+id/bouton_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prendre_photo" />

        <Button
            android:id="@+id/bouton_enregistrer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enregistrer" />

        <!-- Visible uniquement quand on ouvre une fiche existante -->
        <Button
            android:id="@+id/bouton_supprimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/supprimer"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
